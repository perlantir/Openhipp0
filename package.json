{
  "name": "open-hipp0",
  "version": "0.0.0",
  "private": true,
  "description": "Open Hipp0 — local-first autonomous AI agent platform with persistent decision memory and self-learning",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e --filter=@openhipp0/e2e",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.10.2",
    "drizzle-orm": "^0.45.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "playwright-extra": "^4.3.6",
    "prettier": "^3.8.3",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "tsx": "^4.21.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.58.2",
    "vitest": "^3.2.4"
  }
}

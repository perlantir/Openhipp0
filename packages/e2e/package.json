{
  "name": "@openhipp0/e2e",
  "version": "0.0.0",
  "private": true,
  "description": "Phase 8 end-to-end test harness — wires core + memory + bridge + scheduler + watchdog through real code paths with a scripted LLM and an in-memory SQLite DB.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:e2e": "vitest run",
    "test:smoke": "vitest run tests/smoke.test.ts",
    "lint": "eslint src tests --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo coverage"
  },
  "dependencies": {
    "@openhipp0/bridge": "workspace:*",
    "@openhipp0/cli": "workspace:*",
    "@openhipp0/core": "workspace:*",
    "@openhipp0/memory": "workspace:*",
    "@openhipp0/scheduler": "workspace:*",
    "@openhipp0/watchdog": "workspace:*",
    "ws": "^8.18.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/ws": "^8.5.13"
  }
}

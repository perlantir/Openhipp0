{
  "name": "@openhipp0/cli",
  "version": "0.0.0",
  "private": true,
  "description": "hipp0 CLI — init/start/status/doctor/skill/memory/agent/cron (Phase 7)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "hipp0": "./bin/hipp0.js"
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:integration": "vitest run tests/integration",
    "test:smoke": "vitest run tests/smoke.test.ts",
    "lint": "eslint src tests --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo coverage"
  },
  "dependencies": {
    "@openhipp0/bridge": "workspace:*",
    "@openhipp0/core": "workspace:*",
    "@openhipp0/memory": "workspace:*",
    "@openhipp0/scheduler": "workspace:*",
    "@openhipp0/watchdog": "workspace:*",
    "commander": "^14.0.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^11.10.0"
  }
}

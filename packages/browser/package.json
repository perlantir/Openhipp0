{
  "name": "@openhipp0/browser",
  "version": "0.0.0",
  "private": true,
  "description": "Higher-level browser automation — profiles, snapshots, workflows, multi-tab, site memory, network inspector. Primitives (BrowserDriver, engine, SSRF, stealth, credential vault) live in @openhipp0/core/browser.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "eslint src tests --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo coverage"
  },
  "dependencies": {
    "@openhipp0/core": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  }
}

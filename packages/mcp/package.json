{
  "name": "@openhipp0/mcp",
  "version": "0.0.0",
  "private": true,
  "description": "Model Context Protocol server exposing Open Hipp0 tools + memory to MCP clients (Claude Desktop, Cursor, Windsurf, Claude Code).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "hipp0-mcp": "./bin/hipp0-mcp.js"
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:smoke": "vitest run tests/smoke.test.ts",
    "lint": "eslint src tests --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openhipp0/core": "workspace:*",
    "@openhipp0/memory": "workspace:*",
    "@openhipp0/scheduler": "workspace:*",
    "@openhipp0/watchdog": "workspace:*",
    "zod": "^3.25.76"
  }
}

{
  "name": "@openhipp0/relay",
  "version": "0.0.0",
  "private": true,
  "description": "Standalone WebSocket relay for Open Hipp0 mobile ↔ server (Phase 19). Stateless, routes E2E-encrypted envelopes only.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "openhipp0-relay": "./bin/relay.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node bin/relay.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "lint": "eslint src tests --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo coverage"
  },
  "dependencies": {
    "ws": "^8.18.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/ws": "^8.5.13",
    "vitest": "^3.2.4"
  }
}

{
  "name": "@openhipp0/mobile",
  "version": "0.0.0",
  "private": true,
  "description": "Expo / React Native mobile app — Open Hipp0 Remote (Phase 19)",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "web": "expo start --web",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint app src tests --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit",
    "eas:build:ios": "eas build --platform ios --profile preview",
    "eas:build:android": "eas build --platform android --profile preview",
    "clean": "rm -rf .expo dist .turbo coverage node_modules/.cache"
  },
  "dependencies": {
    "@openhipp0/sdk": "workspace:*",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@tanstack/react-query": "^5.59.0",
    "expo": "~52.0.0",
    "expo-auth-session": "~6.0.0",
    "expo-av": "~15.0.0",
    "expo-camera": "~16.0.0",
    "expo-constants": "~17.0.0",
    "expo-crypto": "~14.0.0",
    "expo-haptics": "~14.0.0",
    "expo-linking": "~7.0.0",
    "expo-local-authentication": "~15.0.0",
    "expo-notifications": "~0.29.0",
    "expo-router": "~4.0.0",
    "expo-secure-store": "~14.0.0",
    "expo-sqlite": "~15.0.0",
    "expo-status-bar": "~2.0.0",
    "lucide-react-native": "^0.468.0",
    "nativewind": "^4.1.20",
    "react": "18.3.1",
    "react-native": "0.76.3",
    "react-native-gesture-handler": "~2.20.0",
    "react-native-reanimated": "~3.16.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.1.0",
    "react-native-svg": "15.8.0",
    "tweetnacl": "^1.0.3",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@testing-library/react-native": "^12.9.0",
    "@types/react": "~18.3.12",
    "@types/react-test-renderer": "^18.3.0",
    "jsdom": "^25.0.1",
    "react-test-renderer": "18.3.1",
    "tailwindcss": "^3.4.14",
    "vitest": "^3.2.4"
  }
}

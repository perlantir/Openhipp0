{
  "name": "@openhipp0/eval",
  "version": "0.0.0",
  "private": true,
  "description": "Phase 20 evaluation framework — tiered smoke/regression/full suites, published-benchmark adapters (τ-bench, SWE-bench Lite, AgentBench, GAIA), original memory + self-learning benchmarks, metrics collector, regression thresholds in source.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:smoke": "vitest run tests/suites.test.ts",
    "lint": "eslint src tests --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo coverage"
  },
  "dependencies": {
    "@openhipp0/core": "workspace:*",
    "@openhipp0/memory": "workspace:*",
    "zod": "^3.25.76"
  }
}

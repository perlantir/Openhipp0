    "message": "channel not found"
  },
  "invalidAuth": {
    "type": "slack_webapi_platform_error",
    "slackError": "invalid_auth",
    "message": "invalid auth"
  },
  "missingScope": {
    "type": "slack_webapi_platform_error",
    "slackError": "missing_scope",
    "message": "missing scope"
  },
  "msgTooLong": {
    "type": "slack_webapi_platform_error",
    "slackError": "msg_too_long",
    "message": "msg too long"
  },
  "fatalError": {
    "type": "slack_webapi_platform_error",
    "slackError": "fatal_error",
    "message": "fatal error"
  },
  "http429WithRetryAfter": {
    "type": "slack_webapi_http_error",

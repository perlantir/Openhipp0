{
  "name": "@openhipp0/bridge",
  "version": "0.0.0",
  "private": true,
  "description": "Messaging platform connectors (Discord, Telegram, Slack, Web, CLI)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:integration": "vitest run tests/integration",
    "test:smoke": "vitest run tests/smoke.test.ts",
    "lint": "eslint src tests --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo coverage"
  },
  "dependencies": {
    "@openhipp0/core": "workspace:*",
    "@slack/bolt": "^3.22.0",
    "discord.js": "^14.26.3",
    "grammy": "^1.42.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1"
  }
}

<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX source for the Open Hipp0 Windows MSI installer.
  Build with: candle openhipp0.wxs && light openhipp0.wixobj -o openhipp0.msi

  Requires:
    - WiX Toolset v3.11+ or v4 (syntax below is v3-compatible)
    - Node.js v22+ installed before running (the MSI does not bundle Node)
    - A signing cert for release MSIs; set the OPENHIPP0_SIGN_CERT env
      and sign with `signtool sign /f ... openhipp0.msi` in CI.
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*"
           Name="Open Hipp0"
           Language="1033"
           Version="0.1.0"
           Manufacturer="Open Hipp0 contributors"
           UpgradeCode="A1B2C3D4-E5F6-4789-89AB-CDEF01234567">

    <Package InstallerVersion="500" Compressed="yes" InstallScope="perMachine" />
    <MediaTemplate EmbedCab="yes" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of Open Hipp0 is already installed." />

    <Feature Id="ProductFeature" Title="Open Hipp0 CLI" Level="1">
      <ComponentGroupRef Id="CliFiles" />
      <ComponentRef Id="PathEntry" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="OpenHipp0">
          <Directory Id="BinDir" Name="bin" />
        </Directory>
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="OpenHipp0Shortcut" Name="Open Hipp0" />
      </Directory>
    </Directory>

    <!-- The actual file payload (dist/ + bin/) is authored via heat.exe
         harvesting: `heat dir ../packages/cli -cg CliFiles -gg -scom -sreg -sfrag
         -srd -dr BinDir -out CliFiles.wxs`. This .wxs file consumes the
         generated fragment. -->
    <ComponentGroup Id="CliFiles" Directory="BinDir" />

    <Component Id="PathEntry" Guid="F0F0F0F0-F0F0-4F0F-8F0F-F0F0F0F0F0F0" Directory="BinDir">
      <Environment Id="PATH"
                   Name="PATH"
                   Value="[BinDir]"
                   Permanent="no"
                   Part="last"
                   Action="set"
                   System="yes" />
      <RegistryValue Root="HKLM" Key="Software\OpenHipp0" Name="Installed" Type="integer" Value="1" KeyPath="yes" />
    </Component>

    <Component Id="StartMenuShortcut" Guid="A0A0A0A0-A0A0-4A0A-8A0A-A0A0A0A0A0A0" Directory="OpenHipp0Shortcut">
      <Shortcut Id="StartMenuShortcutCmd"
                Name="Open Hipp0 CLI"
                Description="Open Hipp0 — local-first AI agent platform"
                Target="[%ComSpec]"
                Arguments='/k "[BinDir]hipp0.cmd" --help'
                WorkingDirectory="BinDir" />
      <RemoveFolder Id="OpenHipp0Shortcut" On="uninstall" />
      <RegistryValue Root="HKCU" Key="Software\OpenHipp0" Name="Installed" Type="integer" Value="1" KeyPath="yes" />
    </Component>

    <Icon Id="OpenHipp0.ico" SourceFile="openhipp0.ico" />
    <Property Id="ARPPRODUCTICON" Value="OpenHipp0.ico" />
    <Property Id="ARPHELPLINK" Value="https://docs.openhipp0.dev" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/perlantir/Openhipp0" />
  </Product>
</Wix>
